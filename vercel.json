{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/pcb(.*)",
      "dest": "/$1"
    },
    {
      "src": "/api(.*)",
      "dest": "/$1"
    },
    {
      "src": "/indianavi(.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
